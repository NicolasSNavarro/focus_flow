<div id="<%= dom_id tarea %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Titulo:</strong>
    <%= tarea.titulo %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Completada:</strong>
    <%= tarea.completada? ? "Yes" : "No" %>
  </div>
</div>
