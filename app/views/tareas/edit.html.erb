<%= turbo_frame_tag "modal_frame" do %>
  <div class="bg-white rounded-2xl shadow-xl p-6 border border-orange-100">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-bold text-lg text-stone-800">Editar tarea</h2>
      <button data-action="click->modal#close"
              class="text-stone-400 hover:text-stone-600 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <%= render "form", tarea: @tarea %>
  </div>
<% end %>
