<div id="<%= dom_id(tarea) %>"
     class="group flex items-center gap-3 p-3 rounded-2xl border transition-all
            <%= tarea.completada? ? 'bg-stone-100 border-stone-200 opacity-60' : 'bg-white border-orange-100 shadow-sm hover:shadow-md hover:border-orange-200' %>">

  <%# Checkbox toggle %>
  <%= button_to toggle_tarea_path(tarea), method: :patch,
        class: "shrink-0 w-6 h-6 rounded-full border-2 flex items-center justify-center transition-colors
                #{tarea.completada? ? 'bg-emerald-400 border-emerald-400' : 'border-orange-300 hover:border-orange-500'}" do %>
    <% if tarea.completada? %>
      <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
    <% end %>
  <% end %>

  <%# Título %>
  <span class="flex-1 text-sm <%= tarea.completada? ? 'line-through text-stone-400' : 'text-stone-700' %>">
    <%= tarea.titulo %>
  </span>

  <%# Acciones (aparecen al hover) %>
  <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= link_to edit_tarea_path(tarea),
          data: { turbo_frame: "modal_frame", action: "click->modal#open" },
          class: "p-1 rounded-lg hover:bg-orange-100 text-stone-400 hover:text-orange-600 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
    <% end %>

    <%= button_to tarea_path(tarea), method: :delete,
          data: { turbo_confirm: "¿Eliminar esta tarea?" },
          class: "p-1 rounded-lg hover:bg-red-100 text-stone-400 hover:text-red-500 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
    <% end %>
  </div>
</div>
