<%# Agrega la nueva tarjeta al tope de la lista %>
<%= turbo_stream.prepend "tareas_lista" do %>
  <%= render "tarea_card", tarea: @tarea %>
<% end %>

<%# Actualiza el contador y el botón de agregar %>
<%= turbo_stream.replace "tareas_header" do %>
  <%= render "tareas/header", tareas_count: Tarea.count %>
<% end %>

<%# Cierra el modal vaciando el frame %>
<%= turbo_stream.update "modal_frame", "" %>

<%# Limpia la sugerencia de IA para que no quede desactualizada %>
<%= turbo_stream.update "sugerencia_ia", "" %>
